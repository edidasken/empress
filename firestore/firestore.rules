rules_version='2';service cloud.firestore{match/databases/{database}/documents{match/{document=**}{allow read,write:if false;}match/clinics/{clinicId}{function active(){return request.auth!=null&&exists(/databases/$(database)/documents/clinics/$(clinicId)/memberships/$(request.auth.uid))&&get(/databases/$(database)/documents/clinics/$(clinicId)/memberships/$(request.auth.uid)).data.status=='active';}allow read:if active();allow write:if false;match/{protected=**}{allow read:if active();allow write:if false;}}}}
